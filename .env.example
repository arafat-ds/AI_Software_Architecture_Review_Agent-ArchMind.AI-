# ArchMind AI — Environment Variable Template
#
# Copy this file to .env and fill in all values before running the app.
#
#   cp .env.example .env
#
# SECURITY: Never commit .env to git. It is already listed in .gitignore.
# Rotate any key that is accidentally committed immediately.
#
# Variable reference: backend/config/settings.py
# Validated at startup by pydantic-settings. App will refuse to start
# if a REQUIRED variable is missing or invalid.

# ===========================================================================
# GEMINI API  (REQUIRED)
# ===========================================================================
#
# Source   : Google AI Studio → https://aistudio.google.com/app/apikey
# When     : Phase 10 — before first LLM call or knowledge base load
# How      : Create a Google account → visit AI Studio → click "Get API key"
#            → "Create API key in new project" → copy the key string.
#            Treat this like a password. Do not log it or embed it in code.
#
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini text generation model. Default works for production.
# Options: gemini-2.0-flash | gemini-2.5-flash | gemini-2.5-pro
# gemini-2.0-flash is stable and fast; gemini-2.5-pro is more thorough for complex analysis.
GEMINI_MODEL=gemini-2.5-flash

# Gemini embedding model. Do NOT change unless the Qdrant vector size also changes.
# gemini-embedding-001 produces 3072-dimensional vectors (EMBEDDING_VECTOR_SIZE in constants.py).
# Changing this requires re-loading the entire knowledge base into Qdrant.
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ===========================================================================
# SUPABASE  (REQUIRED)
# ===========================================================================
#
# Source   : Supabase dashboard → https://supabase.com/dashboard
# When     : Phase 11 — before first job submission or report retrieval
# How      :
#   1. Create a free Supabase account at https://supabase.com
#   2. Click "New project". Choose a region close to your users.
#   3. After the project is provisioned (~ 2 min), go to:
#      Project Settings → API
#   4. Copy "Project URL" → paste as SUPABASE_URL below.
#   5. Copy "service_role" key (NOT the anon key) → paste as SUPABASE_KEY below.
#      The service_role key bypasses Row Level Security — keep it secret.
#   6. Deploy the schema: open the Supabase SQL Editor and run the contents of
#      backend/scripts/supabase_schema.sql
#
# SUPABASE_URL must use HTTPS (enforced by settings.py validator).
#
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# ===========================================================================
# QDRANT  (REQUIRED for RAG — but app starts without it)
# ===========================================================================
#
# Qdrant is the vector store for the RAG knowledge base.
# The app starts without Qdrant, but analysis jobs will fail at the RAG node
# if no Qdrant instance is reachable or the collection is empty.
#
# Source   : Self-hosted Docker (local dev) or Qdrant Cloud (production)
# When     : Phase 11 — before loading the knowledge base
#
# --- OPTION A: Local Docker (recommended for local development) ---
#   docker run -d --name qdrant -p 6333:6333 qdrant/qdrant:latest
#   Leave QDRANT_HOST=localhost and QDRANT_PORT=6333 (defaults).
#
# --- OPTION B: Qdrant Cloud (recommended for production) ---
#   1. Create a free cluster at https://cloud.qdrant.io
#   2. Copy the cluster URL (e.g. https://abc123.us-east4.gcp.cloud.qdrant.io)
#      Note: cloud Qdrant uses HTTPS + API key, not plain TCP.
#      The current QdrantClient wrapper uses host+port only.
#      For cloud Qdrant you will need to update infrastructure/qdrant_client.py
#      to use QdrantClient(url=..., api_key=...) instead of host+port.
#      This is a one-line change; tracked as a Phase 13 task.
#
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=archmind_kb

# ===========================================================================
# API / CORS  (OPTIONAL — defaults work for local development)
# ===========================================================================
#
# Comma-separated list of allowed CORS origins.
# In production, set this to your frontend domain only.
# Example: CORS_ORIGINS=["https://archmind.yourdomain.com"]
# The JSON array format is required (pydantic-settings parses it as a list).
#
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ===========================================================================
# CONCURRENCY  (OPTIONAL)
# ===========================================================================
#
# Max simultaneous analysis jobs. Each job holds:
#   - a cloned git repository on disk
#   - active connections to Gemini, Qdrant, and Supabase
#   - ~200–500 MB RAM during LLM calls (prompt + response buffering)
# Start at 2 on a 2 vCPU / 4 GB instance. Scale up with observed usage.
# Valid range: 1–32
#
MAX_CONCURRENT_JOBS=4

# ===========================================================================
# REPOSITORY INGESTION  (OPTIONAL)
# ===========================================================================
#
# Hard timeout for git clone in seconds.
# Large repositories (>100 MB) may need this increased.
# If a clone hangs (e.g. due to SSH auth prompt), it will be killed at this timeout.
#
MAX_CLONE_TIMEOUT_SECONDS=120

# ===========================================================================
# LLM OUTPUT LIMITS  (OPTIONAL)
# ===========================================================================
#
# Max tokens per Gemini generation call.
# 8192 covers all ArchMind prompts with margin.
# Reduce to 4096 to cut latency on fast models (gemini-1.5-flash).
# Do not set below 2048 — architecture report sections will be truncated.
#
LLM_MAX_TOKENS=8192

# ===========================================================================
# LOGGING  (OPTIONAL)
# ===========================================================================
#
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG locally to see per-node LLM call details.
# Use INFO in production.
#
LOG_LEVEL=INFO
